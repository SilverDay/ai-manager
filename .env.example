# =================================================================
# AI Governance Platform - Environment Configuration Template
# =================================================================
# Copy this file to .env and update the values for your environment
#
# REQUIRED CHANGES:
# - Set all database credentials
# - Generate a secure JWT_SECRET (minimum 32 characters)
# - Configure SMTP email settings
# - Update URLs for your domain
# - Set secure passwords where indicated

# Application Configuration
# -------------------------
APP_NAME="AI Governance Platform"

# Environment: development | staging | production
APP_ENV=development

# Enable detailed error messages (set to false in production)
APP_DEBUG=true

# Backend API URL (update for your domain)
APP_URL=http://localhost:8080

# Frontend application URL (update for your domain)
FRONTEND_URL=http://localhost:5173

# Database Configuration
# ----------------------
# MariaDB/MySQL connection settings
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=aigov
DB_USERNAME=aigov_user
DB_PASSWORD=CHANGE_ME_SECURE_PASSWORD_HERE
DB_CHARSET=utf8mb4

# JWT Authentication
# ------------------
# CRITICAL: Generate a cryptographically secure secret (minimum 32 characters)
# You can generate one with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_GENERATE_SECURE_256_BIT_SECRET_HERE_MINIMUM_32_CHARS

# Access token TTL in seconds (900 = 15 minutes)
JWT_ACCESS_TTL=900

# Refresh token TTL in seconds (604800 = 7 days)
JWT_REFRESH_TTL=604800

# Email Configuration (SMTP)
# ---------------------------
# SMTP server settings for sending emails
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your_smtp_username
MAIL_PASSWORD=your_smtp_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="AI Governance Platform"

# File Storage
# ------------
# Directory for storing uploaded documents (ensure writable by web server)
STORAGE_PATH=/var/app/storage/documents

# Maximum upload size in MB
MAX_UPLOAD_SIZE_MB=50

# Rate Limiting (requests per minute)
# -----------------------------------
# Authentication endpoints (login, register, etc.)
RATE_LIMIT_AUTH=10

# API read endpoints (GET requests)
RATE_LIMIT_API_READ=120

# API write endpoints (POST, PUT, DELETE)
RATE_LIMIT_API_WRITE=60

# File upload endpoints
RATE_LIMIT_UPLOAD=10

# CORS Configuration
# ------------------
# Allowed origins for cross-origin requests (comma-separated)
# Add your production domain here
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Security Settings
# -----------------
# Bcrypt password hashing rounds (12-15 recommended)
BCRYPT_COST=12

# Use secure cookies (set to true for HTTPS/production)
SESSION_SECURE=false

# Enable HTTP Strict Transport Security (set to true for HTTPS/production)
HSTS_ENABLED=false

# Background Jobs & Cron
# -----------------------
# Notification check interval in minutes
NOTIFICATION_CRON_INTERVAL=5

# Enable automated data retention cleanup
RETENTION_CLEANUP_ENABLED=true

# Localization
# ------------
# Default application locale
DEFAULT_LOCALE=en

# =================================================================
# SETUP CHECKLIST:
# =================================================================
# □ Copy this file to .env
# □ Set secure DB_PASSWORD
# □ Generate secure JWT_SECRET
# □ Configure SMTP settings
# □ Update APP_URL and FRONTEND_URL for your domain
# □ Add your domain to CORS_ALLOWED_ORIGINS
# □ Set SESSION_SECURE=true and HSTS_ENABLED=true for production
# □ Ensure STORAGE_PATH directory exists and is writable
# □ Run: php scripts/migrate.php
# □ Run: php scripts/seed.php
# □ Run: php scripts/provision-superadmin.php --email your@email.com
# =================================================================