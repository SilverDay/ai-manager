{
    "name": "aigov-platform/backend",
    "description": "AI Governance & EU AI Act Compliance Platform - Backend API",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "firebase/php-jwt": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.8"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-html coverage",
        "stan": "phpstan analyse src tests",
        "cs": "phpcs src tests",
        "cs:fix": "phpcbf src tests",
        "security:audit": "composer audit",
        "security:audit-format": "composer audit --format=table",
        "security:check": "composer audit --no-dev",
        "deps:outdated": "composer outdated --direct",
        "deps:validate": "composer validate --strict",
        "check": [
            "@deps:validate",
            "@security:check",
            "@cs",
            "@stan",
            "@test"
        ],
        "security-audit-full": "php ../scripts/security-audit.php",
        "migrate": "php ../scripts/migrate.php",
        "seed": "php ../scripts/seed.php"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "*": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
