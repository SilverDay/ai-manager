# =================================================================
# AI Governance Platform Backend - Environment Configuration
# =================================================================
# This file is for backend-specific configuration
# Copy the main .env.example from the project root and customize as needed

# Note: The backend will look for .env in both:
# - Project root: /srv/vhosts/aim.silverday.de/.env
# - Backend dir:  /srv/vhosts/aim.silverday.de/backend/.env
#
# Backend .env takes precedence for backend-specific overrides

# Example backend-specific overrides:
# -----------------------------------

# Override log level for backend
# LOG_LEVEL=debug

# Backend-specific database pool settings
# DB_POOL_MIN=2
# DB_POOL_MAX=10

# Backend-specific timeouts
# DB_TIMEOUT=30
# HTTP_TIMEOUT=60

# PHP-specific settings
# MEMORY_LIMIT=256M
# MAX_EXECUTION_TIME=30

# =================================================================
# For full configuration options, see the main .env.example file
# in the project root directory
# ================================================================='